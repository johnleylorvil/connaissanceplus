{
  "family": "konesans-backend-prod",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "1024",
  "memory": "2048",
  "executionRoleArn": "arn:aws:iam::123456789012:role/konesansEcsExecutionRole",
  "taskRoleArn": "arn:aws:iam::123456789012:role/konesansBackendTaskRole",
  "containerDefinitions": [
    {
      "name": "backend",
      "image": "123456789012.dkr.ecr.us-east-1.amazonaws.com/konesans-backend:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 3000,
          "hostPort": 3000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "NODE_ENV", "value": "production" },
        { "name": "PORT", "value": "3000" },
        { "name": "FRONTEND_URL", "value": "https://app.example.com" },
        { "name": "CORS_ORIGINS", "value": "https://app.example.com,https://admin.example.com" },
        { "name": "JWT_EXPIRES_IN", "value": "7d" },
        { "name": "DB_TYPE", "value": "postgres" },
        { "name": "DB_HOST", "value": "db.your-supabase-host.supabase.co" },
        { "name": "DB_PORT", "value": "5432" },
        { "name": "DB_NAME", "value": "postgres" },
        { "name": "DB_SSL", "value": "true" },
        { "name": "DB_SSL_REJECT_UNAUTHORIZED", "value": "false" },
        { "name": "DB_MIGRATIONS_RUN", "value": "true" },
        { "name": "REDIS_HOST", "value": "your-elasticache-endpoint" },
        { "name": "REDIS_PORT", "value": "6379" },
        { "name": "AWS_REGION", "value": "us-east-1" },
        { "name": "CHIME_MEDIA_REGION", "value": "us-east-1" },
        { "name": "SPONSOR_UPLOADS_S3_BUCKET", "value": "konesans-assets-prod" },
        { "name": "SPONSOR_UPLOADS_PUBLIC_BASE_URL", "value": "https://assets.example.com" },
        { "name": "LIVEKIT_URL", "value": "wss://your-livekit-host" },
        { "name": "HLS_BASE_URL", "value": "https://media.example.com" },
        { "name": "HLS_OUTPUT_DIR", "value": "/output" },
        { "name": "LIVEKIT_EGRESS_S3_BUCKET", "value": "konesans-media-prod" },
        { "name": "LIVEKIT_EGRESS_S3_REGION", "value": "us-east-1" },
        { "name": "LIVEKIT_EGRESS_S3_ENDPOINT", "value": "" },
        { "name": "LIVEKIT_EGRESS_S3_FORCE_PATH_STYLE", "value": "false" }
      ],
      "secrets": [
        {
          "name": "JWT_SECRET",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:123456789012:secret:/konesans/backend/JWT_SECRET"
        },
        {
          "name": "ADMIN_SETUP_KEY",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:123456789012:secret:/konesans/backend/ADMIN_SETUP_KEY"
        },
        {
          "name": "DB_USERNAME",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:123456789012:secret:/konesans/backend/DB_USERNAME"
        },
        {
          "name": "DB_PASSWORD",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:123456789012:secret:/konesans/backend/DB_PASSWORD"
        },
        {
          "name": "GOOGLE_CLIENT_ID",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:123456789012:secret:/konesans/backend/GOOGLE_CLIENT_ID"
        },
        {
          "name": "GOOGLE_CLIENT_SECRET",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:123456789012:secret:/konesans/backend/GOOGLE_CLIENT_SECRET"
        },
        {
          "name": "LIVEKIT_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:123456789012:secret:/konesans/backend/LIVEKIT_API_KEY"
        },
        {
          "name": "LIVEKIT_API_SECRET",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:123456789012:secret:/konesans/backend/LIVEKIT_API_SECRET"
        },
        {
          "name": "LIVEKIT_EGRESS_S3_ACCESS_KEY",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:123456789012:secret:/konesans/backend/LIVEKIT_EGRESS_S3_ACCESS_KEY"
        },
        {
          "name": "LIVEKIT_EGRESS_S3_SECRET_KEY",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:123456789012:secret:/konesans/backend/LIVEKIT_EGRESS_S3_SECRET_KEY"
        }
      ],
      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "node -e \"fetch('http://127.0.0.1:' + (process.env.PORT || 3000) + '/health').then((response) => process.exit(response.ok ? 0 : 1)).catch(() => process.exit(1))\""
        ],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 20
      },
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/konesans-backend-prod",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}