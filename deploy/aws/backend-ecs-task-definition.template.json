{
  "family": "konesans-backend-prod",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "1024",
  "memory": "2048",
  "executionRoleArn": "arn:aws:iam::650251714602:role/konesansEcsExecutionRole",
  "taskRoleArn": "arn:aws:iam::650251714602:role/konesansBackendTaskRole",
  "containerDefinitions": [
    {
      "name": "backend",
      "image": "650251714602.dkr.ecr.us-east-1.amazonaws.com/konesans-backend:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 3000,
          "hostPort": 3000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "NODE_ENV", "value": "production" },
        { "name": "PORT", "value": "3000" },
        { "name": "FRONTEND_URL", "value": "__FRONTEND_URL__" },
        { "name": "CORS_ORIGINS", "value": "__CORS_ORIGINS__" },
        { "name": "JWT_EXPIRES_IN", "value": "7d" },
        { "name": "DB_TYPE", "value": "postgres" },
        { "name": "DB_HOST", "value": "__DB_HOST__" },
        { "name": "DB_PORT", "value": "__DB_PORT__" },
        { "name": "DB_NAME", "value": "__DB_NAME__" },
        { "name": "DB_SSL", "value": "true" },
        { "name": "DB_SSL_REJECT_UNAUTHORIZED", "value": "false" },
        { "name": "DB_SYNCHRONIZE", "value": "__DB_SYNCHRONIZE__" },
        { "name": "DB_MIGRATIONS_RUN", "value": "__DB_MIGRATIONS_RUN__" },
        { "name": "SMTP_HOST", "value": "__SMTP_HOST__" },
        { "name": "SMTP_PORT", "value": "__SMTP_PORT__" },
        { "name": "SMTP_SECURE", "value": "__SMTP_SECURE__" },
        { "name": "SMTP_FROM", "value": "__SMTP_FROM__" },
        { "name": "REDIS_HOST", "value": "__REDIS_HOST__" },
        { "name": "REDIS_PORT", "value": "6379" },
        { "name": "AWS_REGION", "value": "us-east-1" },
        { "name": "CHIME_MEDIA_REGION", "value": "us-east-1" },
        { "name": "SPONSOR_UPLOADS_S3_BUCKET", "value": "__SPONSOR_UPLOADS_S3_BUCKET__" },
        { "name": "SPONSOR_UPLOADS_PUBLIC_BASE_URL", "value": "__SPONSOR_UPLOADS_PUBLIC_BASE_URL__" },
        { "name": "LIVEKIT_URL", "value": "__LIVEKIT_URL__" },
        { "name": "HLS_BASE_URL", "value": "__HLS_BASE_URL__" },
        { "name": "HLS_OUTPUT_DIR", "value": "/output" },
        { "name": "LIVEKIT_EGRESS_S3_BUCKET", "value": "__LIVEKIT_EGRESS_S3_BUCKET__" },
        { "name": "LIVEKIT_EGRESS_S3_REGION", "value": "__LIVEKIT_EGRESS_S3_REGION__" },
        { "name": "LIVEKIT_EGRESS_S3_ENDPOINT", "value": "__LIVEKIT_EGRESS_S3_ENDPOINT__" },
        { "name": "LIVEKIT_EGRESS_S3_FORCE_PATH_STYLE", "value": "__LIVEKIT_EGRESS_S3_FORCE_PATH_STYLE__" }
      ],
      "secrets": [
        {
          "name": "JWT_SECRET",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:650251714602:secret:/konesans/backend/JWT_SECRET"
        },
        {
          "name": "ADMIN_SETUP_KEY",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:650251714602:secret:/konesans/backend/ADMIN_SETUP_KEY"
        },
        {
          "name": "DB_USERNAME",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:650251714602:secret:/konesans/backend/DB_USERNAME"
        },
        {
          "name": "DB_PASSWORD",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:650251714602:secret:/konesans/backend/DB_PASSWORD"
        },
        {
          "name": "SMTP_USER",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:650251714602:secret:/konesans/backend/SMTP_USER"
        },
        {
          "name": "SMTP_PASS",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:650251714602:secret:/konesans/backend/SMTP_PASS"
        }
      ],
      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "node -e \"fetch('http://127.0.0.1:' + (process.env.PORT || 3000) + '/health').then((response) => process.exit(response.ok ? 0 : 1)).catch(() => process.exit(1))\""
        ],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 20
      },
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/konesans-backend-prod",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}