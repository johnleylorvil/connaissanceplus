PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://admin.localhost:5173

JWT_SECRET=change-me-local-jwt-secret
JWT_EXPIRES_IN=7d
ADMIN_SETUP_KEY=change-me-local-admin-setup-key

# Database
DB_TYPE=sqlite
DB_SQLITE_PATH=konesans.sqlite

# For Postgres instead of SQLite, switch DB_TYPE and fill these values.
# DB_TYPE=postgres
# DB_HOST=localhost
# DB_PORT=5432
# DB_USERNAME=postgres
# DB_PASSWORD=postgres
# DB_NAME=konesans_plus
# DB_SSL=true
# DB_SSL_REJECT_UNAUTHORIZED=false
# DB_MIGRATIONS_RUN=true

# Arena live stage (LiveKit RTC)
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret

# Arena spectator playback
HLS_BASE_URL=http://localhost:3000/hls
HLS_OUTPUT_DIR=/output
# For production HLS to S3, configure these and point HLS_BASE_URL to your CDN origin.
# LIVEKIT_EGRESS_S3_BUCKET=your-media-bucket
# LIVEKIT_EGRESS_S3_REGION=us-east-1
# LIVEKIT_EGRESS_S3_ACCESS_KEY=
# LIVEKIT_EGRESS_S3_SECRET_KEY=
# LIVEKIT_EGRESS_S3_ENDPOINT=
# LIVEKIT_EGRESS_S3_FORCE_PATH_STYLE=false

# Viewer heartbeat
REDIS_HOST=localhost
REDIS_PORT=6379

# AWS-backed uploads / services
# AWS_REGION=us-east-1
# SPONSOR_UPLOADS_S3_BUCKET=your-assets-bucket
# SPONSOR_UPLOADS_PUBLIC_BASE_URL=https://cdn.example.com